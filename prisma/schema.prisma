generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  name             String?
  passwordHash     String?
  stripeCustomerId String?   @unique
  locale           String    @default("en") // 'en' or 'fr'
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  instance         Instance?
  accounts         Account[]
  sessions         Session[]
}

model Instance {
  id               String           @id @default(cuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           InstanceStatus   @default(pending)
  appUrl           String?
  dokployProjectId String?
  dokployAppId     String?
  channel          String?
  channelToken     String?
  aiProvider       String?
  aiApiKey         String?
  activeModel      String?          // Currently active model (e.g., "openai/gpt-4o")
  agentLocale      String           @default("en") // Agent communication language
  enabledSkills    String[]         @default([])
  stripeSubId      String?          @unique
  stripePriceId    String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  providers        ProviderConfig[]
}

model ProviderConfig {
  id         String   @id @default(cuid())
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  provider   String   // 'openai', 'anthropic', 'openrouter'
  apiKey     String
  isActive   Boolean  @default(false)
  isValid    Boolean? // null = untested, true = valid, false = invalid
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([instanceId, provider])
}

enum InstanceStatus {
  pending
  provisioning
  active
  failed
  cancelled
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Skill {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String
  category    String
  mcpConfig   Json
  iconUrl     String?
  active      Boolean @default(true)
}
