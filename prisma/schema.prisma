generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String              @id @default(cuid())
  email                 String              @unique
  name                  String?
  passwordHash          String?
  stripeCustomerId      String?             @unique
  locale                String              @default("en") // 'en' or 'fr'
  subscriptionStatus    SubscriptionStatus  @default(inactive)
  creditsBalance        Int                 @default(0)
  lifetimeCreditsGranted Int                @default(0)
  telegramUserId        String?             @unique
  telegramUsername      String?
  telegramLinkedAt      DateTime?
  telegramBotToken      String?
  telegramBotId         String?
  telegramChatId        String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  instance              Instance?
  workspace             Workspace?
  accounts              Account[]
  sessions              Session[]
  telegramLinkTokens    TelegramLinkToken[]
}

model Workspace {
  id        String            @id @default(cuid())
  userId    String            @unique
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String            @default("My Workspace")
  pages     Page[]
  folders   WorkspaceFolder[]
  files     WorkspaceFile[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model Page {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Page?      @relation("PageTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    Page[]     @relation("PageTree")
  title       String
  pageType    PageType   @default(standard)
  status      PageStatus @default(active)
  position    Int        @default(0)
  content     Json?
  isRoot      Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([workspaceId, status, position])
  @@index([parentId, position])
}

model Instance {
  id               String         @id @default(cuid())
  userId           String         @unique
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status           InstanceStatus @default(pending)
  appUrl           String?
  dokployProjectId String?
  dokployAppId     String?
  aiProvider       String?
  activeModel      String?        // Currently active model (e.g., "openai/gpt-4o")
  agentLocale      String         @default("en") // Agent communication language
  enabledSkills    String[]       @default([])
  stripeSubId      String?        @unique
  stripePriceId    String?
  gatewayToken     String?        // OpenClaw gateway authentication token
  containerHost    String?        // Container hostname for internal WS connection
  gatewayPort      Int            @default(18789)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model TelegramLinkToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token      String   @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
}

enum InstanceStatus {
  pending
  provisioning
  active
  failed
  cancelled
}

enum SubscriptionStatus {
  inactive
  active
  past_due
  cancelled
}

enum PageType {
  standard
  database
  board
  dashboard
  capture
}

enum PageStatus {
  active
  archived
}

enum WorkspaceActor {
  user
  agent
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WorkspaceFolder {
  id          String            @id @default(cuid())
  workspaceId String
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name        String
  parentId    String?
  parent      WorkspaceFolder?  @relation("WorkspaceFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children    WorkspaceFolder[] @relation("WorkspaceFolderTree")
  files       WorkspaceFile[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([workspaceId, parentId])
}

model WorkspaceFile {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      WorkspaceFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  name        String
  path        String
  mimeType    String
  sizeBytes   Int
  content     String?
  storageKey  String
  createdBy   WorkspaceActor
  description String?
  indexed     Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([workspaceId, folderId, deletedAt])
  @@index([workspaceId, deletedAt])
}

model Skill {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String
  category    String
  mcpConfig   Json
  iconUrl     String?
  active      Boolean @default(true)
}
