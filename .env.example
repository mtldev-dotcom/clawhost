# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://clawhost:clawhost@localhost:5432/clawhost

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Encryption (generate with: openssl rand -base64 32)
# Used to encrypt user API keys at rest
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Dokploy (your Dokploy instance) - optional for local dev
DOKPLOY_URL=https://deploy.nickybruno.com
DOKPLOY_API_KEY=your-dokploy-api-key

# GCP Configuration (for provisioning/ssh)
# Optional - used when not running with Docker socket
GCP_PROJECT_ID=your-gcp-project
GCP_ZONE=us-central1-a

# Local dev: OpenClaw Docker image (used when Dokploy is not configured)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Rate Limiting (requests per window)
# Format: count_minutes (default: 100_15 = 100 requests per 15 minutes)
RATE_LIMIT_AUTH=10_15
RATE_LIMIT_API=100_15
