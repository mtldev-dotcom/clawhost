# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://clawhost:clawhost@localhost:5432/clawhost

# Auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# Stripe (from https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Dokploy (your Dokploy instance) - optional for local dev
DOKPLOY_URL=https://deploy.nickybruno.com
DOKPLOY_API_KEY=your-dokploy-api-key

# Local dev: OpenClaw Docker image (used when Dokploy is not configured)
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
